<Window x:Class="HomeWork_WPF_Day1_Task2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HomeWork_WPF_Day1_Task2"
        mc:Ignorable="d"
        Title="Светофор" Height="450" Width="200">
    <Grid>
        <Ellipse 
            Name="Red"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Height="100" Margin="0,25,0,0"
            Width="100"
            Stroke="Black" 
            Fill="Gray"
            />
        <Ellipse 
            x:Name="Yellow"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Height="100" Margin="0,135,0,0"
            Width="100"
            Stroke="Black"
            Fill="Gray"
            />
        <Ellipse 
            x:Name="Green"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Height="100" Margin="0,245,0,0"
            Width="100"
            Stroke="Black"
            Fill="Gray"
            />
        <Button 
            Content="Next" 
            HorizontalAlignment="Center"  
            VerticalAlignment="Top"
            Margin="0,365,0,0"
            Height="30"
            Width="100"
            ButtonBase.Click="Button_NextColour"/>
    </Grid>
</Window>
